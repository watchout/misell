{
  "name": "misell-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud monitoring MVP for Misell signage devices.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "check": "node --check server.js && node --check public/admin.js && node --check scripts/backup-sqlite.mjs && node --check scripts/smoke-backup.mjs && node --check scripts/smoke-reporting.mjs",
    "smoke:mvp-foundation": "node scripts/smoke-mvp-foundation.mjs",
    "smoke:mvp-audit-fixes": "node scripts/smoke-mvp-audit-fixes.mjs",
    "smoke:backup": "node scripts/smoke-backup.mjs",
    "smoke:reporting": "node scripts/smoke-reporting.mjs",
    "backup": "scripts/backup-sqlite.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-basic-auth": "^1.2.1",
    "multer": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
