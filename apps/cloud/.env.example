PORT=3200
HOST=127.0.0.1
APP_ENV=local

ADMIN_USER=admin
ADMIN_PASSWORD=change-me
REQUIRE_ADMIN_AUTH=1

DEVICE_TOKEN_PEPPER=replace-with-long-random-pepper
DB_PATH=./data/misell-cloud.sqlite

# SQLite backup
MISELL_CLOUD_BACKUP_DIR=./data/backups
MISELL_CLOUD_BACKUP_RETENTION_DAYS=30
MISELL_CLOUD_BACKUP_GZIP=1
MISELL_CLOUD_BACKUP_OPS_AUDIT_DIR=./data/backup-ops-audit
MISELL_CLOUD_BACKUP_OPS_AUDIT_RETENTION_DAYS=400
MISELL_BACKUP_OPERATOR=ops
MISELL_BACKUP_CONTEXT=scheduled
MISELL_CLOUD_RESTORE_DRILL_EVIDENCE_DIR=./data/restore-drills
MISELL_CLOUD_RESTORE_DRILL_EVIDENCE_RETENTION_DAYS=400
MISELL_RESTORE_DRILL_OPERATOR=ops
MISELL_RESTORE_DRILL_CONTEXT=manual
# Product/commercial restore drills should fail if a backup manifest is missing.
# MISELL_RESTORE_DRILL_REQUIRE_MANIFEST=1

# Optional client-side backup encryption with age public-key recipients.
# Paid/product offsite backups should set ENCRYPTION=age and REQUIRE_ENCRYPTION=1.
# Keep private identity keys off this host, out of Git, DB dumps, backups, and manifests.
# MISELL_CLOUD_BACKUP_ENCRYPTION=age
# MISELL_CLOUD_BACKUP_REQUIRE_ENCRYPTION=1
# MISELL_CLOUD_BACKUP_AGE_RECIPIENTS=age1examplepublicrecipient
# MISELL_CLOUD_BACKUP_AGE_CLI=age
# MISELL_RESTORE_DRILL_AGE_IDENTITY_FILE=/secure/offhost/age-identity.txt
# MISELL_RESTORE_DRILL_AGE_CLI=age

# Optional S3-compatible offsite backup.
# Configure the bucket/prefix and credentials in the deployed env file.
# MISELL_CLOUD_BACKUP_S3_URI=s3://example-bucket/misell-cloud
# MISELL_CLOUD_BACKUP_S3_ENDPOINT_URL=https://s3.example.com
# MISELL_CLOUD_BACKUP_S3_STORAGE_CLASS=STANDARD_IA
# MISELL_CLOUD_BACKUP_S3_SSE=AES256
# MISELL_CLOUD_BACKUP_S3_TIMEOUT_MS=300000
# MISELL_CLOUD_BACKUP_AWS_CLI=aws
# AWS_ACCESS_KEY_ID=replace-with-access-key
# AWS_SECRET_ACCESS_KEY=replace-with-secret-key
# AWS_DEFAULT_REGION=ap-northeast-1
