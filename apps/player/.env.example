PORT=3000
APP_ENV=local

ADMIN_USER=admin
ADMIN_PASSWORD=change-me
REQUIRE_ADMIN_AUTH=1

MISELL_TENANT_ID=TEN-LOCAL
MISELL_STORE_ID=STO-LOCAL
MISELL_LOCATION_ID=LOC-LOCAL
MISELL_SCREEN_GROUP_ID=SG-LOCAL
MISELL_DEVICE_ID=DEV-LOCAL-001
MISELL_DEVICE_NAME=local-dev-player
MISELL_DEVICE_TOKEN=replace-with-generated-device-token
MISELL_RELEASE_ID=local-0.1.0
MISELL_RELEASE_CHANNEL=dev
MISELL_CONFIG_VERSION=local-001

# Optional. When set, scripts/emit-heartbeat.sh posts /api/status here.
# MISELL_HEARTBEAT_URL=https://example.com/api/device/heartbeat

UPLOAD_MAX_MB=500
